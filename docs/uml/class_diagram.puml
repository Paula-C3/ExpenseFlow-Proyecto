' ===== DIAGRAMA 1 (MVP / SIMPLE) =====
@startuml
skinparam classAttributeIconSize 0

' --- Interfaces y Abstracciones ---
interface IExpenseRepository {
  + save(request: ExpenseRequest): ExpenseRequest
  + findById(id: String): ExpenseRequest
  + findByEmployee(employeeId: String): List<ExpenseRequest>
}

interface IEventPublisher {
  + publish(event: SystemEvent): void
}

' --- Patrón Strategy/Policy para Reglas de Aprobación ---
interface IApprovalPolicy {
  + evaluate(request: ExpenseRequest): ApprovalResult
}

class StandardApprovalPolicy implements IApprovalPolicy {
  + evaluate(request: ExpenseRequest): ApprovalResult
}

class HighAmountApprovalPolicy implements IApprovalPolicy {
  + evaluate(request: ExpenseRequest): ApprovalResult
}

' --- Entidades Principales ---
class User {
  - id: String
  - name: String
  - role: Role
  - email: String
}

enum Role {
  EMPLOYEE
  MANAGER
  FINANCE_ANALYST
  FINANCE_ADMIN
  SYSTEM_ADMIN
}

class ExpenseRequest {
  - id: String
  - amount: Double
  - category: String
  - description: String
  - receiptReference: String
  - state: ExpenseState
  - createdAt: Date
  - employeeId: String
  + submit(): void
  + approve(userId: String): void
  + reject(userId: String, reason: String): void
  + requestChanges(userId: String, comment: String): void
  + markAsPaid(userId: String): void
  + setState(state: ExpenseState): void
}

' --- Patrón State ---
abstract class ExpenseState {
  + handleApproval(request: ExpenseRequest, userId: String): void
  + handleRejection(request: ExpenseRequest, userId: String, reason: String): void
}

class DraftState extends ExpenseState
class SubmittedState extends ExpenseState
class ManagerReviewState extends ExpenseState
class FinanceReviewState extends ExpenseState
class ChangesRequestedState extends ExpenseState
class ReadyForPaymentState extends ExpenseState
class PaidState extends ExpenseState

' --- Eventos ---
abstract class SystemEvent {
  - eventId: String
  - occurredAt: Date
  - expenseId: String
}

class ExpenseSubmittedEvent extends SystemEvent
class ExpenseApprovedEvent extends SystemEvent
class ChangesRequestedEvent extends SystemEvent

class NotificationService {
  + sendInAppNotification(userId: String, message: String): void
}

' --- Auditoría ---
class AuditLog {
  - id: String
  - expenseId: String
  - userId: String
  - action: String
  - timestamp: Date
}

class ApprovalDecision {
  - id: String
  - expenseId: String
  - approverId: String
  - level: String
  - decisionDate: Date
}

' --- Relaciones ---
User --> Role
ExpenseRequest *-- ExpenseState
ExpenseRequest --> IApprovalPolicy : uses
IEventPublisher ..> SystemEvent : publishes
NotificationService ..> SystemEvent : listens to
ExpenseRequest "1" *-- "*" ApprovalDecision
ExpenseRequest "1" *-- "*" AuditLog
IExpenseRepository "1" --> "*" ExpenseRequest

@enduml


' ===== DIAGRAMA 2 (DDD COMPLETO - AYELEN) =====
@startuml class_diagram

skinparam classAttributeIconSize 0
skinparam linetype ortho

package "domain.entities" {
    class Request {
        +id: int
        +employee_id: int
        +title: str
        +amount: float
        +category: ExpenseCategory
        +status: RequestStatus
        +state: IRequestState
        +approve(approver_id, comment)
        +reject(rejector_id, reason)
        +submit()
        +cancel()
    }

    class Notification {
        +id: int
        +user_id: int
        +title: str
        +message: str
        +notification_type: str
        +is_read: bool
        +created_at: datetime
    }

    class AuditLog {
        +id: int
        +actor_id: int
        +entity_type: str
        +entity_id: int
        +action: str
        +previous_state: str
        +new_state: str
        +timestamp: datetime
    }
}

package "domain.states" {
    interface IRequestState <<interface>> {
        +approve(request, approver_id, comment)
        +reject(request, rejector_id, reason)
        +submit(request)
        +cancel(request)
    }

    class DraftState implements IRequestState
    class SubmittedState implements IRequestState
    class ManagerReviewState implements IRequestState
    class FinanceReviewState implements IRequestState
    class ApprovedState implements IRequestState
    class RejectedState implements IRequestState
    class ChangesRequestedState implements IRequestState
    class ReadyForPaymentState implements IRequestState
    class PaidState implements IRequestState
}

Request o--> IRequestState

package "domain.events" {
    class RequestCreatedEvent
    class RequestApprovedEvent
    class RequestRejectedEvent
    class ChangesRequestedEvent
    class ExpensePaidEvent
}

package "domain.interfaces" {
    interface IEventBus {
        +publish(event)
        +subscribe(event_type, listener)
    }
}

package "infrastructure.event_bus" {
    class EventBus implements IEventBus
    class NotificationListener
    class AuditListener
}

EventBus --> NotificationListener
EventBus --> AuditListener
NotificationListener --> Notification
AuditListener --> AuditLog

package "domain.factories" {
    class RequestFactory
}

RequestFactory --> Request

package "application.patterns" {
    interface ICommand {
        +execute()
    }

    class ApproveRequestCommand implements ICommand
    class RejectRequestCommand implements ICommand
    class CommandHandler
}

CommandHandler --> ICommand

package "application.patterns" {
    interface IApprovalStrategy
    class SimpleApprovalStrategy
    class HighRiskApprovalStrategy
    class ApprovalStrategySelector
}

ApprovalStrategySelector --> IApprovalStrategy

package "application.patterns" {
    abstract class BaseRequestProcessor
    class ApproveRequestProcessor
    class RejectRequestProcessor
}

package "domain.interfaces" {
    interface IRequestRepository
    interface INotificationRepository
    interface IAuditLogRepository
}

package "application.use_cases" {
    class CreateRequestUseCase
    class ApproveRequestUseCase
    class RejectRequestUseCase
    class GetRequestsByRoleUseCase
    class GetRequestDetailUseCase
}

@enduml