@startuml use_case

left to right direction
skinparam packageStyle rectangle

actor Employee
actor Manager
actor "Finance Analyst" as FA
actor "Finance Admin" as FAd
actor "System Admin" as SA

rectangle ExpenseFlow {

    package "Employee Flow" {
        usecase "Crear solicitud de gasto" as UC1
        usecase "Enviar solicitud para aprobación" as UC2
        usecase "Cancelar solicitud" as UC3
        usecase "Reenviar solicitud tras correcciones" as UC4
        usecase "Consultar historial y detalle de solicitudes" as UC5
    }

    package "Manager Flow" {
        usecase "Listar solicitudes pendientes del equipo" as UC6
        usecase "Ver detalle de solicitud" as UC7
        usecase "Aprobar solicitud de gasto" as UC8
        usecase "Rechazar solicitud de gasto" as UC9
    }

    package "Finance Flow" {
        usecase "Listar solicitudes en revisión de Finanzas" as UC10
        usecase "Solicitar cambios sobre una solicitud" as UC11
        usecase "Rechazar solicitud desde Finanzas" as UC12
        usecase "Aprobar gastos mayores a 500 USD" as UC13
        usecase "Marcar solicitud como pagada (PAID)" as UC14
    }

    package "Audit & Notifications" {
        usecase "Ver notificaciones propias" as UC15
        usecase "Marcar notificación como leída" as UC16
        usecase "Consultar logs de auditoría" as UC17
    }
}

Employee --> UC1
Employee --> UC2
Employee --> UC3
Employee --> UC4
Employee --> UC5
Employee --> UC15
Employee --> UC16

Manager --> UC6
Manager --> UC7
Manager --> UC8
Manager --> UC9
Manager --> UC15
Manager --> UC16

FA --> UC10
FA --> UC11
FA --> UC12
FA --> UC15
FA --> UC16

FAd --> UC13
FAd --> UC14
FAd --> UC15
FAd --> UC16

SA --> UC17

UC8 ..> UC9 : <<extends>>

@enduml
